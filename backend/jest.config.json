{
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "testMatch": ["**/*.test.ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": {
        "strict": true,
        "esModuleInterop": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false
      }
    }]
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/index.ts"],
  "coverageDirectory": "coverage",
  "testTimeout": 30000
}
