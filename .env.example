# Environment Variables — EventBook Backend
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Local: matches docker-compose.yml defaults
DATABASE_URL=postgresql://eventbook:eventbook@localhost:5432/eventbook

# ── Redis ────────────────────────────────────────────────────────────────────
# Local: matches docker-compose.yml defaults
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# OPEN QUESTION: JWT_EXPIRES_IN value to be confirmed before Step 3.
# OPEN QUESTION: bcrypt cost factor (BCRYPT_ROUNDS) to be confirmed before Step 3.
JWT_SECRET=replace-this-with-a-random-32-plus-char-string
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12
